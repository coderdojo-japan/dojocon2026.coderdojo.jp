---
/**
 * 各セクション共通の見出し。
 * 英語タイトルを中央に、下に日本語サブタイトルを表示する。
 */
interface Props {
  /** 英語タイトル（例: "Outline"） */
  title: string;
  /** 日本語サブタイトル（例: "開催概要"） */
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<header class="mb-10 text-center">
  <h2 class="text-navy flex items-center justify-center gap-3 text-2xl font-bold sm:text-3xl">
    <span aria-hidden="true" class="text-accent">✎</span>
    <span>{title}</span>
    <span aria-hidden="true" class="text-accent">✎</span>
  </h2>
  {subtitle && <p class="text-ink/70 mt-2 text-sm">{subtitle}</p>}
</header>
