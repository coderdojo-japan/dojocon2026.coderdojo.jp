---
// サイト共通ヘッダー（モックの l-header を移植。相対パスは絶対パスに変換）
const REGISTER_URL = "https://dojocon-japan.doorkeeper.jp/events/198206";
const CONTACT_URL = "https://forms.gle/TMX7WMkjz2tADSGe6";

// ナビ項目。href はサイトルート基準の絶対パス。external は別タブで開く外部リンク。
const navItems = [
  { href: "/", label: "ホーム" },
  { href: "/#outline", label: "開催概要" },
  { href: "/sessions/", label: "セッション" },
  { href: "/events/", label: "イベント" },
  { href: "/news/", label: "お知らせ" },
  { href: "/#sponsor", label: "スポンサー" },
  { href: "#", label: "タイムテーブル" },
  { href: CONTACT_URL, label: "お問い合わせ", external: true },
];
---

<header class="l-header" id="js-header">
  <div class="l-header__inner">
    <div class="l-header__bar">
      <a class="l-header__logo-link" href="/">
        <img
          class="l-header__logo-img"
          src="/images/common/logo.webp"
          alt="DojoCon Japan 2026"
          width="553"
          height="173"
        />
      </a>
      <div class="l-header__bar-right">
        <a class="l-header__link l-header__link--btn" href={REGISTER_URL} target="_blank" rel="noopener noreferrer"
          >参加登録</a
        >
        <button
          class="l-header__hamburger"
          id="js-hamburger"
          type="button"
          aria-expanded="false"
          aria-label="メニューを開く"
        >
          <span class="l-header__hamburger-line"></span>
          <span class="l-header__hamburger-line"></span>
          <span class="l-header__hamburger-line"></span>
        </button>
      </div>
    </div>
    <nav class="l-header__nav" id="js-nav">
      <ul class="l-header__list">
        {
          navItems.map((item) => (
            <li>
              <a
                class="l-header__link"
                href={item.href}
                {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a class="l-header__link l-header__link--btn" href={REGISTER_URL} target="_blank" rel="noopener noreferrer"
            >参加登録</a
          >
        </li>
      </ul>
    </nav>
  </div>
</header>
