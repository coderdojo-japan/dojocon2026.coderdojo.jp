---
import { formatNewsDate } from "../lib/news";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"news">[];
}
const { posts } = Astro.props;
---

{
  posts.length === 0 ? (
    <p class="p-news__empty">お知らせは準備中です。</p>
  ) : (
    <ul class="p-news__list">
      {posts.map((post) => (
        <li class="p-news__item">
          <a href={`/news/${post.id}`}>
            <time class="p-news__date" datetime={post.data.date.toISOString().slice(0, 10)}>
              {formatNewsDate(post.data.date)}
            </time>
            <span class={`p-news__category p-news__category--${post.data.color}`}>{post.data.label}</span>
            <p class="p-news__text">{post.data.title}</p>
          </a>
        </li>
      ))}
    </ul>
  )
}
