---
import Section from "../Section.astro";
import NewsList from "../NewsList.astro";
import { getNews } from "../../lib/news";

// 最新 5 件を表示
const posts = await getNews(5);
---

<Section id="news" title="News" subtitle="お知らせ">
  <NewsList posts={posts} />

  {
    posts.length > 0 && (
      <p class="mt-8 text-center">
        <a href="/news" class="text-accent underline">
          &raquo; お知らせ一覧を見る
        </a>
      </p>
    )
  }
</Section>
