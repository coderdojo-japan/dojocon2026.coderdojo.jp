---
// スタッフセクション（p-staff）。url があればカードをリンクにする。
import Heading from "../Heading.astro";
import { staff, STAFF_NO_IMAGE } from "../../data/staff";
---

<section class="p-staff">
  <div class="p-staff__inner l-inner">
    <Heading title="Staff" subtitle="スタッフ" />
    {
      staff.length === 0 ? (
        <p class="p-staff__empty">スタッフ紹介は準備中です。</p>
      ) : (
        <ul class="p-staff__grid">
          {staff.map((member) => {
            const Card = member.url ? "a" : "div";
            return (
              <li class="p-staff__item">
                <Card
                  class="p-staff__card"
                  {...(member.url ? { href: member.url, target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  <div class="p-staff__img-wrap">
                    <img
                      class="p-staff__img"
                      src={member.avatar ?? STAFF_NO_IMAGE}
                      width="150"
                      height="150"
                      alt={member.name}
                    />
                  </div>
                  <p class="p-staff__name">{member.name}</p>
                </Card>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</section>
