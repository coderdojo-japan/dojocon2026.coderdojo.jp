---
// スポンサーセクション（p-sponsor）。tier ごとにロゴグリッド／名前リストを表示。
import Heading from "../Heading.astro";
import { sponsorTiers } from "../../data/sponsors";

// スポンサーが 1 件でも登録されている tier だけ表示する
const activeTiers = sponsorTiers.filter((tier) => tier.sponsors.length > 0);
---

<section id="sponsor" class="p-sponsor">
  <div class="p-sponsor__inner l-inner">
    <Heading title="Sponsor" subtitle="スポンサー" />

    {
      activeTiers.length === 0 ? (
        <p class="p-sponsor__empty">スポンサーは募集中です。決定し次第こちらでご紹介します。</p>
      ) : (
        activeTiers.map((tier) => (
          <div class="p-sponsor__tier">
            <hgroup class="p-sponsor__tier-heading">
              <h3 class="p-sponsor__tier-title">{tier.title}</h3>
              <p class="p-sponsor__tier-subtitle">{tier.subtitle}</p>
            </hgroup>

            {tier.display === "logo" ? (
              <ul class={`p-sponsor__logos p-sponsor__logos--${tier.key}`}>
                {tier.sponsors.map((sponsor) => (
                  <li class="p-sponsor__logo-item">
                    <a class="p-sponsor__logo-link" href={sponsor.url ?? "#"}>
                      <img class="p-sponsor__logo-img" src={sponsor.logo} alt={sponsor.name} />
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <ul class="p-sponsor__names">
                {tier.sponsors.map((sponsor) => (
                  <li class="p-sponsor__name-item">
                    {sponsor.url ? (
                      <a class="p-sponsor__name" href={sponsor.url} target="_blank" rel="noopener noreferrer">
                        {sponsor.name}
                      </a>
                    ) : (
                      <span class="p-sponsor__name">{sponsor.name}</span>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      )
    }
  </div>
</section>
