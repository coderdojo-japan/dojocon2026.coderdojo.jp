---
// セッション/イベントのカードグリッドセクション（p-program）。
// variant で種別を切り替え、items はコレクションのエントリを渡す。
import type { CollectionEntry } from "astro:content";
import Heading from "../Heading.astro";
import FrontButton from "../FrontButton.astro";
import ProgramCard from "../ProgramCard.astro";
import { SESSION_NO_IMAGE, EVENT_NO_IMAGE } from "../../lib/program";

interface Props {
  variant: "session" | "event";
  title: string;
  subtitle: string;
  items: CollectionEntry<"sessions">[] | CollectionEntry<"events">[];
  moreHref: string;
  moreLabel: string;
}
const { variant, title, subtitle, items, moreHref, moreLabel } = Astro.props;

const basePath = variant === "session" ? "/sessions/" : "/events/";
const noImage = variant === "session" ? SESSION_NO_IMAGE : EVENT_NO_IMAGE;
---

<section class="p-program">
  <div class="p-program__inner l-inner">
    <Heading title={title} subtitle={subtitle} />
    {
      items.length === 0 ? (
        <p class="p-program__empty">{subtitle}は準備中です。お楽しみに！</p>
      ) : (
        <div class="p-program__grid">
          {items.map((item) => (
            <ProgramCard
              variant={variant}
              href={`${basePath}${item.id}`}
              title={item.data.title}
              image={item.data.image ?? noImage}
              type={item.data.type}
              target={item.data.target}
              speaker={variant === "session" ? (item as CollectionEntry<"sessions">).data.speaker : undefined}
              needsReservation={variant === "event" ? (item as CollectionEntry<"events">).data.needsReservation : false}
            />
          ))}
        </div>
      )
    }
    <div class="p-program__more">
      <FrontButton href={moreHref}>{moreLabel}</FrontButton>
    </div>
  </div>
</section>
