---
import Section from "../Section.astro";
import type { ProgramItem } from "../../data/program";

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  items: ProgramItem[];
  alt?: boolean;
}
const { id, title, subtitle, items, alt = false } = Astro.props;
---

<Section id={id} title={title} subtitle={subtitle} alt={alt}>
  {
    items.length === 0 ? (
      <p class="text-ink/60 text-center">{subtitle ?? title}は準備中です。お楽しみに！</p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item) => (
          <article class="overflow-hidden rounded-xl border border-black/5 bg-white shadow-sm">
            {item.image && <img src={item.image} alt="" class="aspect-video w-full object-cover" />}
            <div class="p-5">
              <h3 class="text-navy font-bold">{item.title}</h3>
              {item.speaker && <p class="text-ink/70 mt-1 text-sm">{item.speaker}</p>}
              {item.description && <p class="text-ink/80 mt-3 text-sm leading-relaxed">{item.description}</p>}
              {item.url && (
                <a href={item.url} class="text-accent mt-3 inline-block text-sm underline">
                  詳しく見る
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )
  }
</Section>
