---
import { site } from "../../data/site";
---

<section id="organizers" class="scroll-mt-20 px-6 py-16 text-center sm:py-20">
  <div class="mx-auto max-w-3xl">
    <div>
      <p class="text-accent font-mono text-sm tracking-widest">Organized by</p>
      <div class="text-ink/90 mt-4 space-y-1">
        <p class="font-bold">DojoCon Japan 実行委員会</p>
        <p>
          <a href={site.links.coderdojoJapan} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
            一般社団法人 CoderDojo Japan
          </a>
        </p>
      </div>
    </div>

    <div class="mt-12">
      <p class="text-accent font-mono text-sm tracking-widest">Supported by</p>
      <p class="text-ink/90 mt-4">
        <a href={site.links.coderdojoFoundation} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
          CoderDojo Foundation
        </a>
      </p>
    </div>
  </div>
</section>
