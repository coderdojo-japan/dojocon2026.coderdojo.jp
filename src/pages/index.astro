---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Theme from "../components/sections/Theme.astro";
import Outline from "../components/sections/Outline.astro";
import About from "../components/sections/About.astro";
import News from "../components/sections/News.astro";
import Keynote from "../components/sections/Keynote.astro";
import ProgramSection from "../components/sections/ProgramSection.astro";
import Sponsors from "../components/sections/Sponsors.astro";
import Organizers from "../components/sections/Organizers.astro";
import Contact from "../components/sections/Contact.astro";
import Staff from "../components/sections/Staff.astro";
import { getSessions, getEvents } from "../lib/program";

const sessions = await getSessions(6);
const events = await getEvents(6);
---

<BaseLayout>
  <main id="home">
    <Hero />
    <Theme />
    <Outline />
    <About />
    <News />
    <Keynote />
    <ProgramSection
      variant="session"
      title="Session"
      subtitle="セッション"
      items={sessions}
      moreHref="/sessions/"
      moreLabel="全てのセッションをみる"
    />
    <ProgramSection
      variant="event"
      title="Event"
      subtitle="イベント"
      items={events}
      moreHref="/events/"
      moreLabel="全てのイベントをみる"
    />
    <Sponsors />
    <Organizers />
    <Contact />
    <Staff />
  </main>
</BaseLayout>
