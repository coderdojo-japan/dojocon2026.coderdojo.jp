---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Outline from "../components/sections/Outline.astro";
import AboutCoderDojo from "../components/sections/AboutCoderDojo.astro";
import AboutDojoCon from "../components/sections/AboutDojoCon.astro";
import News from "../components/sections/News.astro";
import Keynote from "../components/sections/Keynote.astro";
import ProgramSection from "../components/sections/ProgramSection.astro";
import Organizers from "../components/sections/Organizers.astro";
import Sponsors from "../components/sections/Sponsors.astro";
import Contact from "../components/sections/Contact.astro";
import Staff from "../components/sections/Staff.astro";
import { sessions, events } from "../data/program";
---

<BaseLayout>
  <Hero />
  <Outline />
  <AboutCoderDojo />
  <AboutDojoCon />
  <News />
  <Keynote />
  <ProgramSection id="sessions" title="Session" subtitle="セッション" items={sessions} alt />
  <ProgramSection id="events" title="Event" subtitle="イベント" items={events} />
  <Organizers />
  <Sponsors />
  <Contact />
  <Staff />
</BaseLayout>
