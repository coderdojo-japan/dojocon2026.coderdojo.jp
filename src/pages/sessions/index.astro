---
import ArchiveLayout from "../../layouts/ArchiveLayout.astro";
import ProgramCard from "../../components/ProgramCard.astro";
import { getSessions, SESSION_NO_IMAGE } from "../../lib/program";

const sessions = await getSessions();
---

<ArchiveLayout title="Session" subtitle="セッション">
  {
    sessions.length === 0 ? (
      <p class="p-program__empty">セッションは準備中です。お楽しみに！</p>
    ) : (
      <div class="p-program__grid">
        {sessions.map((item) => (
          <ProgramCard
            variant="session"
            href={`/sessions/${item.id}`}
            title={item.data.title}
            image={item.data.image ?? SESSION_NO_IMAGE}
            type={item.data.type}
            target={item.data.target}
            speaker={item.data.speaker}
          />
        ))}
      </div>
    )
  }
</ArchiveLayout>
